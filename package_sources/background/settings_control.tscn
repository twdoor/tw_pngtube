[gd_scene format=3]

[ext_resource type="Script" path="res://package_sources/background/settings_control.gd" id="1_settings"]

[node name="BackgroundSettingsControl" type="VBoxContainer"]
size_flags_horizontal = 3
theme_override_constants/separation = 6
script = ExtResource("1_settings")

[node name="ModeRow" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="Label" type="Label" parent="ModeRow"]
custom_minimum_size = Vector2(70, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 11
text = "Type"

[node name="ModeOption" type="OptionButton" parent="ModeRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3

[node name="ColorRow" type="HBoxContainer" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="Label" type="Label" parent="ColorRow"]
custom_minimum_size = Vector2(70, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 11
text = "Color"

[node name="ColorPicker" type="ColorPickerButton" parent="ColorRow"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 28)
layout_mode = 2
size_flags_horizontal = 3
edit_alpha = true

[node name="ImageRow" type="HBoxContainer" parent="."]
unique_name_in_owner = true
visible = false
layout_mode = 2

[node name="ImagePathLabel" type="Label" parent="ImageRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 10
text = "No image selected"
text_overrun_behavior = 3

[node name="ChooseImageButton" type="Button" parent="ImageRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Choose…"

[node name="ImageDialog" type="FileDialog" parent="."]
unique_name_in_owner = true
title = "Choose background image"
initial_position = 1
size = Vector2i(760, 520)
transient = true
exclusive = true
use_native_dialog = false
access = 2
filters = PackedStringArray("*.png ; PNG images", "*.webp ; WebP images", "*.jpg,*.jpeg ; JPEG images")
